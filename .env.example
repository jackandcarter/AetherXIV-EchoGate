# Optional local override template.
# The repo already includes .env.defaults. Copy this file to .env.local only
# when your machine needs different values. .env.local is ignored by Git.

# MariaDB/MySQL admin connection used only for setup/import.
# On Ubuntu socket-auth installs, setup-local-db can fall back to sudo root.
DB_HOST=localhost
DB_PORT=3306
DB_ADMIN_USER=
DB_ADMIN_PASS=
DB_ADMIN_SUDO=0

# Database and application account used by the AetherXIV servers and PHP services.
# These are local development defaults. Change both password values together
# if this machine is exposed beyond your local dev environment.
DB_NAME=ffxiv_server
DB_APP_HOST=127.0.0.1
DB_APP_PORT=3306
DB_APP_USER=aetherxiv
DB_APP_PASS=aether_dev
DB_APP_HOSTS="localhost 127.0.0.1"

AETHER_DB_HOST=127.0.0.1
AETHER_DB_PORT=3306
AETHER_DB_NAME=ffxiv_server
AETHER_DB_USER=aetherxiv
AETHER_DB_PASS=aether_dev

# Legacy compatibility for old local scripts/configs and existing deployments.
METEOR_DB_HOST=127.0.0.1
METEOR_DB_PORT=3306
METEOR_DB_NAME=ffxiv_server
METEOR_DB_USER=aetherxiv
METEOR_DB_PASS=aether_dev

# Optional path to your local user-owned FFXIV 1.x client root.
CLIENT_DIR=
